# Copy to `.env` in the project root. Loaded by `config.ts` via dotenv; missing vars exit the process.

# Solana HTTP RPC (Connection)
RPC_ENDPOINT=

# Same provider’s WebSocket URL (wss://…)
RPC_WEBSOCKET_ENDPOINT=

# Jito block-engine hostname only, no scheme (required by config; matches your region)
BLOCKENGINE_URL=frankfurt.mainnet.block-engine.jito.wtf

# HTTPS URL for JSON-RPC `sendBundle` POST (`executor/lilJito.ts`), e.g.
# https://frankfurt.mainnet.block-engine.jito.wtf/api/v1/bundles
LILJITO_RPC_ENDPOINT=

# Tip in SOL; config multiplies by 1e9 → lamports
JITO_FEE=0.0002

# Priority fee: micro-lamports per compute unit (`ComputeBudgetProgram.setComputeUnitPrice`)
COMPUTE_UNIT_PRICE=6000000
